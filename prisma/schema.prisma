generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "rhel-vany-1.0.0", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}
model User {
  id            String            @id @default(uuid())
  name          String?
  email         String            @unique
  emailVerified DateTime?
  image         String?
  fullName      String?
  nim           String?
  faculty       String?
  studyProgram  String?
  role          String            @default("student")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  articles      Article[]
  likes         ArticleLike[]
  bookmarks     ArticleBookmark[]
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Article {
  id            String            @id @default(uuid())
  authorId      String
  categoryId    String?
  title         String
  slug          String            @unique
  abstract      String?           @db.Text
  contentJson   Json?
  content       String?           @db.Text 
  coverImageUrl String?
  keywords      String?           @db.Text
  status        String            @default("draft")
  readCount     Int               @default(0)
  publishedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  author        User              @relation(fields: [authorId], references: [id])
  category      Category?         @relation(fields: [categoryId], references: [id])
  tags          ArticleTag[]
  likes         ArticleLike[]
  bookmarks     ArticleBookmark[]

  @@map("articles")
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  color       String?
  articles    Article[]
}

model Tag {
  id       String       @id @default(uuid())
  name     String       @unique
  slug     String       @unique
  articles ArticleTag[]
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id])
  tag       Tag     @relation(fields: [tagId], references: [id])

  @@id([articleId, tagId])
}

model ArticleLike {
  articleId String
  userId    String
  createdAt DateTime @default(now())
  article   Article  @relation(fields: [articleId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@id([articleId, userId])
}

model ArticleBookmark {
  articleId String
  userId    String
  createdAt DateTime @default(now())
  article   Article  @relation(fields: [articleId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@id([articleId, userId])
}